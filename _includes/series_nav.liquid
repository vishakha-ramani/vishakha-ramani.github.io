{% comment %}
  Navigation for the freshness-in-shared-memory trilogy.
  Usage, top of post:    {% include series_nav.liquid part=2 %}
  Usage, bottom of post: {% include series_nav.liquid part=2 position="footer" %}
{% endcomment %}
{% assign series_urls = "/blog/2026/a-lock-can-make-data-fresher/|/blog/2026/the-router-that-measured-freshness/|/blog/2026/freshness-has-a-memory-bill/" | split: "|" %}
{% assign series_titles = "A lock can make data fresher|The router that measured freshness|Freshness has a memory bill" | split: "|" %}
{% assign cur = include.part | minus: 1 %}
{% if include.position == "footer" %}
<div class="series-nav-footer">
  <span>
    {% if include.part > 1 %}{% assign prev = cur | minus: 1 %}&larr; <a href="{{ series_urls[prev] | relative_url }}">{{ series_titles[prev] }}</a>{% endif %}
  </span>
  <span>
    {% if include.part < 3 %}{% assign next = cur | plus: 1 %}<a href="{{ series_urls[next] | relative_url }}">{{ series_titles[next] }}</a> &rarr;{% endif %}
  </span>
</div>
{% else %}
<div class="series-nav">
  <span class="series-nav-title">Freshness in shared memory · Part {{ include.part }} of 3</span><br>
  {% for title in series_titles %}{% assign i = forloop.index0 %}{% if i == cur %}{{ title }}{% else %}<a href="{{ series_urls[i] | relative_url }}">{{ title }}</a>{% endif %}{% unless forloop.last %} · {% endunless %}{% endfor %}
</div>
{% endif %}
